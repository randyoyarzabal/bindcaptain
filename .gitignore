# --- Production zone files on a live host often live outside this clone (see docs).
# This repo ignores config/ so laptops don't commit live zones by mistake.
# Authoritative zone backups can live in a private mirror (not documented here in-tree).
# Private second Git remote URL (self-hosted); never commit — see local/git-mirror.url.example
local/git-mirror.url

# Configuration backups
backups/
config.backup
config.backup.*/
config/
config

# Runtime logs
logs/

# Test outputs and configs
tests/results/
tests/test-configs/

# BIND runtime data
*.jnl
*.bak
*.swp
*~

# OS files
.DS_Store
Thumbs.db

# Editor files
*.vim
*.swp
.vscode/
.idea/

