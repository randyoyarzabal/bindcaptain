# BindCaptain runtime environment overrides.
#
# Copy to e.g. /etc/default/bindcaptain (or wherever your systemd unit
# loads EnvironmentFile=) and uncomment the values you want to set.
# Anything not set here uses the script defaults.

# --- Container layout ----------------------------------------------------

# Directory containing your named.conf and zone files. Mounted into the
# container at /etc/named.conf and /var/named.
#BINDCAPTAIN_CONFIG_PATH=/opt/bindcaptain/config

# Container network mode.
#   bridge (default) — private CNI bridge IP; host:port forwarded with -p.
#                      Best isolation. NOT suitable when this server must
#                      NOTIFY external secondaries (the bridge IP isn't
#                      routable from secondaries; named drops NOTIFY with
#                      EADDRNOTAVAIL). See docs/networking.md.
#   host             — share the host's network namespace. named binds host
#                      interfaces directly. REQUIRED when this server is a
#                      primary that NOTIFIES external secondaries.
#BINDCAPTAIN_NETWORK_MODE=host

# --- Reverse-zone management ---------------------------------------------

# Optional override for which subnets BindCaptain rewrites PTR zones for.
# Leave unset to auto-discover from your named.conf (every primary
# X.X.X.in-addr.arpa zone is included).
#
# Format: comma- or space-separated entries of the form
#   <subnet-prefix>:<reverse-zone-name>:<zone-dir>
#
# Example (override two /24 reverse zones grouped under a forward dir):
#BINDCAPTAIN_PTR_NETWORKS="10.0.1:1.0.10.in-addr.arpa:example.com,10.0.2:2.0.10.in-addr.arpa:example.com"

# --- Logging -------------------------------------------------------------

# All record actions are sent to the system logger (journald + syslog) with
# tag "bindcaptain". Reachable via:
#   journalctl -t bindcaptain -f
#   grep bindcaptain /var/log/messages   (RHEL family)
# Rotation for the shadow file is handled by config-examples/bindcaptain.logrotate.

# --- BIND debug ----------------------------------------------------------

# Container's BIND debug level (0-9). 0=quiet, 1=normal, 3=verbose
# (includes "sent notify to <ip>" and other useful trace events).
#BIND_DEBUG_LEVEL=1

# Timezone inside the container (affects log timestamps).
#TZ=UTC
